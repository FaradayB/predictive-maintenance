# Copy this file to .env and fill in your values. Never commit .env.

# --- Google / Gemini ---------------------------------------------------------
# Free key from https://aistudio.google.com/app/apikey
GOOGLE_API_KEY=your-google-ai-studio-key-here
# Generation model used by the LLM chains.
GOOGLE_MODEL=gemini-2.0-flash
# Embedding model used by the RAG pipeline.
GOOGLE_EMBEDDING=models/text-embedding-004

# --- PostgreSQL --------------------------------------------------------------
DB_HOST=localhost
DB_PORT=5432
DB_NAME=vehicle_maintenance
DB_USER=vpm_user
DB_PASSWORD=change-me

# --- Service wiring ----------------------------------------------------------
# Where the Streamlit apps reach the FastAPI backend.
API_URL=http://localhost:8010
